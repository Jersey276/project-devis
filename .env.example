# Variables consumed by docker-compose.prod.yml on the production server.
# Copy this file to `.env` next to docker-compose.prod.yml and fill it in.

# Prefix for all GHCR images. Each service appends "/<name>:<tag>" to it.
# Example resolved image: ghcr.io/jersey276/project-devis/front:latest
IMAGE_PREFIX=ghcr.io/jersey276/project-devis

# Image tag pulled by every service. Default is "latest"; override to a specific
# commit SHA to roll back to a previous build (see docs/DEPLOY.md).
IMAGE_TAG=latest

# Host port published by the front container (container still listens on 3000).
# Default 3001 avoids conflicts with other services already bound on 3000.
FRONT_PORT=3001
