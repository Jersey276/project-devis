# Variables consumed by docker-compose.prod.yml on the production server.
# Copy this file to `.env` next to docker-compose.prod.yml and fill it in.

# Prefix for all GHCR images. Each service appends "-<name>:latest" to it.
# Example: ghcr.io/jersey276/project-devis-front:latest
IMAGE_PREFIX=ghcr.io/jersey276/project-devis
